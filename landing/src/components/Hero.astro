---
const stats = [
  { value: '9', label: 'países' },
  { value: '112', label: 'endpoints' },
  { value: '4', label: 'planes' },
];
---

<section class="relative overflow-hidden pt-28 pb-20 lg:pt-36 lg:pb-28">
  <div class="absolute inset-0 bg-gradient-to-br from-violet-50/80 via-white to-violet-50/40" />

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <div class="animate-fade-in-up mb-5 inline-flex items-center gap-2 rounded-full border border-violet-200 bg-violet-50 px-4 py-1.5 text-xs font-semibold text-violet-700">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Multi-país &middot; Multi-moneda &middot; Multi-tenant
        </div>

        <h1 class="animate-fade-in-up mb-6 text-4xl font-extrabold leading-[1.1] tracking-tight text-gray-900 sm:text-5xl lg:text-[3.5rem]">
          El POS que <span class="gradient-text">entiende</span> la facturación fiscal de Latinoamérica
        </h1>

        <p class="animate-fade-in-up animation-delay-200 mb-8 max-w-lg text-lg leading-relaxed text-gray-500">
          Vende, factura y controla tu inventario en 9 países. Multimoneda, multi-almacen y listo para cumplir con cada régimen fiscal regional.
        </p>

        <div class="animate-fade-in-up animation-delay-400 flex flex-wrap items-center gap-4">
          <a href="https://wa.me/584247253544?text=Hola%2C%20quiero%20probar%20TiendaPOS" target="_blank" class="glow-hover inline-flex items-center gap-2.5 rounded-xl bg-violet-600 px-7 py-3.5 text-sm font-bold text-white no-underline shadow-lg shadow-violet-500/20 transition-all hover:-translate-y-0.5 hover:bg-violet-700">
            Comenzar prueba gratis
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#planes" class="inline-flex items-center gap-2.5 rounded-xl border-2 border-gray-200 bg-white px-7 py-3.5 text-sm font-bold text-gray-700 no-underline transition-all hover:border-violet-300 hover:text-violet-700">
            Ver planes
          </a>
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-8 border-t border-gray-200 pt-6">
          {stats.map((s) => (
            <div>
              <div class="text-2xl font-black text-gray-900">{s.value}</div>
              <div class="text-xs font-medium text-gray-400">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Dashboard mockup -->
      <div class="animate-float relative hidden lg:block">
        <div class="rounded-2xl border border-gray-200 bg-white shadow-2xl shadow-violet-500/5">
          <div class="flex items-center gap-2 border-b border-gray-100 px-4 py-3">
            <span class="h-2.5 w-2.5 rounded-full bg-red-400" />
            <span class="h-2.5 w-2.5 rounded-full bg-yellow-400" />
            <span class="h-2.5 w-2.5 rounded-full bg-green-400" />
            <span class="ml-3 rounded bg-gray-100 px-3 py-1 text-[10px] font-medium text-gray-400">app.tiendapos.com</span>
          </div>
          <div class="p-5">
            <div class="mb-4 flex items-center justify-between">
              <div class="text-sm font-bold text-gray-900">Dashboard</div>
              <div class="rounded-lg bg-violet-50 px-3 py-1 text-xs font-semibold text-violet-600">Hoy</div>
            </div>
            <div class="mb-4 grid grid-cols-3 gap-3">
              <div class="rounded-xl border border-gray-100 bg-gray-50/50 p-3">
                <div class="mb-1 text-[10px] text-gray-400">Ventas</div>
                <div class="text-lg font-bold text-gray-900">$12,480</div>
                <div class="text-[10px] text-green-500">+12.5%</div>
              </div>
              <div class="rounded-xl border border-gray-100 bg-gray-50/50 p-3">
                <div class="mb-1 text-[10px] text-gray-400">Productos</div>
                <div class="text-lg font-bold text-gray-900">347</div>
                <div class="text-[10px] text-violet-500">Activos</div>
              </div>
              <div class="rounded-xl border border-gray-100 bg-gray-50/50 p-3">
                <div class="mb-1 text-[10px] text-gray-400">Clientes</div>
                <div class="text-lg font-bold text-gray-900">89</div>
                <div class="text-[10px] text-blue-500">Este mes</div>
              </div>
            </div>
            <div class="space-y-2">
              <div class="flex items-center justify-between rounded-lg border border-gray-100 px-3 py-2">
                <div class="flex items-center gap-2">
                  <div class="h-2 w-2 rounded-full bg-green-400" />
                  <span class="text-xs text-gray-600">Venta #1042</span>
                </div>
                <span class="text-xs font-semibold text-gray-900">$245.00</span>
              </div>
              <div class="flex items-center justify-between rounded-lg border border-gray-100 px-3 py-2">
                <div class="flex items-center gap-2">
                  <div class="h-2 w-2 rounded-full bg-blue-400" />
                  <span class="text-xs text-gray-600">Factura F-089</span>
                </div>
                <span class="text-xs font-semibold text-gray-900">$1,780.00</span>
              </div>
              <div class="flex items-center justify-between rounded-lg border border-gray-100 px-3 py-2">
                <div class="flex items-center gap-2">
                  <div class="h-2 w-2 rounded-full bg-amber-400" />
                  <span class="text-xs text-gray-600">Crédito pendiente</span>
                </div>
                <span class="text-xs font-semibold text-gray-900">$560.00</span>
              </div>
            </div>
          </div>
        </div>
        <div class="pointer-events-none absolute -inset-4 -z-10 rounded-3xl bg-violet-500/5 blur-2xl" />
      </div>
    </div>
  </div>
</section>
