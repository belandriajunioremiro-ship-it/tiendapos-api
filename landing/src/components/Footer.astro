---
import SocialIcons from '../components/SocialIcons';
const year = new Date().getFullYear();
---

<!-- Modals -->
<div class="modal-overlay fixed inset-0 z-50 hidden items-center justify-center bg-black/40 p-6 backdrop-blur-sm" id="modalPrivacidad">
  <div class="w-full max-w-[540px] max-h-[80vh] overflow-y-auto rounded-2xl bg-white p-8 shadow-2xl">
    <div class="mb-5 flex items-center justify-between">
      <h3 class="text-lg font-bold text-[#1a1a2e]">Política de Privacidad</h3>
      <button class="modal-close rounded-lg p-1.5 text-gray-400 transition-all hover:bg-violet-50 hover:text-violet-600">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="space-y-3 text-sm leading-relaxed text-gray-600">
      <p><strong>Información que recopilamos:</strong> Datos de registro (nombre, correo electrónico, contraseña), información de la tienda (RIF/NIT/RFC, razón social, dirección) y datos transaccionales del sistema.</p>
      <p><strong>Uso de la información:</strong> Proveer el servicio: procesar ventas, generar facturas, gestionar inventario y mantener tu cuenta activa. No compartimos datos con terceros sin consentimiento.</p>
      <p><strong>Seguridad:</strong> Comunicaciones cifradas vía HTTPS. Tokens de autenticación almacenados de forma segura.</p>
      <p><strong>Contacto:</strong> Para consultas sobre privacidad, escríbenos vía WhatsApp.</p>
    </div>
  </div>
</div>

<div class="modal-overlay fixed inset-0 z-50 hidden items-center justify-center bg-black/40 p-6 backdrop-blur-sm" id="modalTerminos">
  <div class="w-full max-w-[540px] max-h-[80vh] overflow-y-auto rounded-2xl bg-white p-8 shadow-2xl">
    <div class="mb-5 flex items-center justify-between">
      <h3 class="text-lg font-bold text-[#1a1a2e]">Términos del Servicio</h3>
      <button class="modal-close rounded-lg p-1.5 text-gray-400 transition-all hover:bg-violet-50 hover:text-violet-600">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="space-y-3 text-sm leading-relaxed text-gray-600">
      <p><strong>Uso del servicio:</strong> TiendaPOS es un POS para gestionar operaciones comerciales. El usuario se compromete a usarlo de forma ética y conforme a las leyes de su país.</p>
      <p><strong>Responsabilidad fiscal:</strong> TiendaPOS facilita datos formales de facturación, pero no es un sistema fiscal certificado. El usuario es responsable de sus obligaciones tributarias.</p>
      <p><strong>Disponibilidad:</strong> Nos esforzamos por mantener el servicio 24/7, pero no garantizamos disponibilidad ininterrumpida.</p>
      <p><strong>Modificaciones:</strong> Nos reservamos el derecho de modificar estos términos. Los cambios serán notificados a través del sistema.</p>
    </div>
  </div>
</div>

<div class="modal-overlay fixed inset-0 z-50 hidden items-center justify-center bg-black/40 p-6 backdrop-blur-sm" id="modalLegal">
  <div class="w-full max-w-[540px] max-h-[80vh] overflow-y-auto rounded-2xl bg-white p-8 shadow-2xl">
    <div class="mb-5 flex items-center justify-between">
      <h3 class="text-lg font-bold text-[#1a1a2e]">Aviso Legal</h3>
      <button class="modal-close rounded-lg p-1.5 text-gray-400 transition-all hover:bg-violet-50 hover:text-violet-600">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="space-y-3 text-sm leading-relaxed text-gray-600">
      <p><strong>Propiedad intelectual:</strong> TiendaPOS es un software desarrollado de forma independiente. Todos los derechos reservados.</p>
      <p><strong>Exención fiscal:</strong> Este sistema no está certificado por ninguna autoridad tributaria. Recomendamos consultar con un contador para garantizar el cumplimiento local.</p>
      <p><strong>Protección de datos:</strong> Los datos se almacenan en servidores de terceros (Neon.tech, Render) con sus propias certificaciones de seguridad.</p>
      <p><strong>Jurisdicción:</strong> Este aviso se rige por las leyes de Venezuela. Cualquier controversia será resuelta en Caracas.</p>
    </div>
  </div>
</div>

<!-- Footer -->
<footer class="w-full bg-gradient-to-b from-violet-700 to-violet-900 px-6 py-12 text-center reveal">
  <div class="mx-auto max-w-[1140px]">
    <!-- Logo + description -->
    <div class="mb-6">
      <div class="mb-2 text-xl font-extrabold text-white/90">Tienda<span class="text-amber-300">POS</span></div>
      <p class="mx-auto max-w-[400px] text-sm text-violet-200/70">Sistema de punto de venta multi-país para Latinoamérica.</p>
    </div>

    <!-- Social icons -->
    <div class="mb-6">
      <SocialIcons client:visible />
    </div>

    <!-- Links -->
    <div class="mb-6 text-sm">
      <a href="#" class="footer-link font-medium text-violet-200/70 no-underline transition-colors hover:text-white" data-modal="modalPrivacidad">Privacidad</a>
      <span class="mx-2 text-violet-400/30">·</span>
      <a href="#" class="footer-link font-medium text-violet-200/70 no-underline transition-colors hover:text-white" data-modal="modalTerminos">Términos</a>
      <span class="mx-2 text-violet-400/30">·</span>
      <a href="#" class="footer-link font-medium text-violet-200/70 no-underline transition-colors hover:text-white" data-modal="modalLegal">Aviso legal</a>
    </div>

    <!-- Copyright -->
    <div class="border-t border-white/10 pt-6 text-xs text-violet-300/50">
      &copy; {year} TiendaPOS &mdash; Backend en Render &middot; Base de datos en Neon
    </div>
  </div>
</footer>

<!-- Back to top -->
<button id="backToTop" class="fixed bottom-20 right-6 z-50 flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-lg shadow-gray-200/50 text-gray-400 opacity-0 invisible transition-all hover:text-violet-600 hover:shadow-violet-200/50" aria-label="Volver arriba">
  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
</button>

<script is:inline>
function openModal(id) {
  document.getElementById(id).classList.remove('hidden');
  document.getElementById(id).classList.add('flex');
  document.body.style.overflow = 'hidden';
}
function closeModal(id) {
  document.getElementById(id).classList.add('hidden');
  document.getElementById(id).classList.remove('flex');
  document.body.style.overflow = '';
}
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.modal-close').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var modal = this.closest('.modal-overlay');
      if (modal) closeModal(modal.id);
    });
  });
  document.querySelectorAll('.modal-overlay').forEach(function(overlay) {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) closeModal(this.id);
    });
  });
  document.querySelectorAll('.footer-link').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      var modalId = this.getAttribute('data-modal');
      if (modalId) openModal(modalId);
    });
  });

  // Back to top
  var backBtn = document.getElementById('backToTop');
  if (backBtn) {
    window.addEventListener('scroll', function() {
      if (window.scrollY > 500) {
        backBtn.classList.remove('opacity-0', 'invisible');
        backBtn.classList.add('opacity-100', 'visible');
      } else {
        backBtn.classList.add('opacity-0', 'invisible');
        backBtn.classList.remove('opacity-100', 'visible');
      }
    }, { passive: true });
    backBtn.addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
});
</script>
