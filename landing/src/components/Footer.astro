---
const year = new Date().getFullYear();
---

<!-- CTA Section -->
<section class="bg-gradient-to-br from-violet-600 to-violet-800 px-6 py-24 text-center">
  <div class="mx-auto max-w-2xl reveal">
    <h2 class="mb-5 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
      ¿Listo para vender sin fronteras?
    </h2>
    <p class="mx-auto mb-8 max-w-md text-lg leading-relaxed text-violet-200">
      Únete a los comercios que ya confían en TiendaPOS. Prueba gratis 14 días, sin tarjeta.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a href="https://wa.me/584247253544?text=Hola%2C%20quiero%20probar%20TiendaPOS" target="_blank" class="inline-flex items-center gap-2.5 rounded-xl bg-white px-7 py-3.5 text-sm font-bold text-violet-700 no-underline shadow-lg transition-all hover:-translate-y-0.5 hover:shadow-xl">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        Comenzar prueba gratis
      </a>
      <a href="https://wa.me/584247253544?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20TiendaPOS" target="_blank" class="inline-flex items-center gap-2.5 rounded-xl border-2 border-white/30 px-7 py-3.5 text-sm font-bold text-white no-underline transition-all hover:border-white/60">
        Hablar con ventas
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-gray-900 px-6 py-12">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <div class="mb-3 text-lg font-extrabold text-white">Tienda<span class="text-violet-400">POS</span></div>
        <p class="text-sm leading-relaxed text-gray-400">Sistema de punto de venta multi-país para Latinoamérica.</p>
      </div>
      <div>
        <div class="mb-3 text-xs font-bold uppercase tracking-widest text-gray-500">Producto</div>
        <div class="space-y-2">
          <a href="#funciones" class="block text-sm text-gray-400 no-underline transition-colors hover:text-white">Funciones</a>
          <a href="#paises" class="block text-sm text-gray-400 no-underline transition-colors hover:text-white">Países</a>
          <a href="#planes" class="block text-sm text-gray-400 no-underline transition-colors hover:text-white">Planes</a>
          <a href="#faq" class="block text-sm text-gray-400 no-underline transition-colors hover:text-white">FAQ</a>
        </div>
      </div>
      <div>
        <div class="mb-3 text-xs font-bold uppercase tracking-widest text-gray-500">Legal</div>
        <div class="space-y-2">
          <a href="#" class="footer-link block text-sm text-gray-400 no-underline transition-colors hover:text-white" data-modal="modalPrivacidad">Privacidad</a>
          <a href="#" class="footer-link block text-sm text-gray-400 no-underline transition-colors hover:text-white" data-modal="modalTerminos">Términos</a>
          <a href="#" class="footer-link block text-sm text-gray-400 no-underline transition-colors hover:text-white" data-modal="modalLegal">Aviso legal</a>
        </div>
      </div>
      <div>
        <div class="mb-3 text-xs font-bold uppercase tracking-widest text-gray-500">Contacto</div>
        <div class="flex items-center gap-3">
          <a href="https://wa.me/584247253544" target="_blank" class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-all hover:bg-[#25d366] hover:text-white" aria-label="WhatsApp">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 448 512"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
          </a>
          <a href="#" class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-all hover:bg-pink-500 hover:text-white" aria-label="Instagram">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7z"/></svg>
          </a>
          <a href="#" class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-all hover:bg-blue-500 hover:text-white" aria-label="Facebook">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 512 512"><path d="M504 256C504 119 393 8 256 8S8 119 8 256c0 123.78 90.69 226.38 209.25 245V327.69h-63V256h63v-54.64c0-62.15 37-96.48 93.67-96.48 27.14 0 55.52 4.84 55.52 4.84v61h-31.28c-30.8 0-40.41 19.12-40.41 38.73V256h68.78l-11 71.69h-57.78V501C413.31 482.38 504 379.78 504 256z"/></svg>
          </a>
          <a href="#" class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-all hover:bg-black hover:text-white" aria-label="TikTok">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 448 512"><path d="M448 209.91a210.06 210.06 0 0 1-122.77-39.25v178.72A162.55 162.55 0 1 1 185 188.31v89.89a74.62 74.62 0 1 0 52.23 71.18V0h88a121.18 121.18 0 0 0 1.86 22.17 122.18 122.18 0 0 0 53.91 80.22 121.43 121.43 0 0 0 67 20.14z"/></svg>
          </a>
        </div>
      </div>
    </div>
    <div class="mt-10 border-t border-white/10 pt-6 text-center text-xs text-gray-500">
      &copy; {year} TiendaPOS &mdash; API en Render &middot; Base de datos en Neon
    </div>
  </div>
</footer>

<!-- Modals -->
<div class="modal-overlay fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-6 backdrop-blur-sm" id="modalPrivacidad">
  <div class="w-full max-w-lg rounded-2xl bg-white p-8 shadow-2xl">
    <div class="mb-4 flex items-center justify-between"><h3 class="text-lg font-bold text-gray-900">Política de Privacidad</h3><button class="modal-close rounded-lg p-1.5 text-gray-400 hover:text-gray-700"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
    <div class="space-y-3 text-sm leading-relaxed text-gray-600"><p><strong>Datos que recopilamos:</strong> Nombre, correo, datos de la tienda (RIF/NIT/RFC) y datos transaccionales del sistema.</p><p><strong>Uso:</strong> Proveer el servicio: procesar ventas, generar facturas y gestionar inventario. No compartimos datos con terceros.</p><p><strong>Seguridad:</strong> Comunicaciones cifradas vía HTTPS. Tokens almacenados de forma segura con Sanctum.</p></div>
  </div>
</div>
<div class="modal-overlay fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-6 backdrop-blur-sm" id="modalTerminos">
  <div class="w-full max-w-lg rounded-2xl bg-white p-8 shadow-2xl">
    <div class="mb-4 flex items-center justify-between"><h3 class="text-lg font-bold text-gray-900">Términos del Servicio</h3><button class="modal-close rounded-lg p-1.5 text-gray-400 hover:text-gray-700"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
    <div class="space-y-3 text-sm leading-relaxed text-gray-600"><p><strong>Uso del servicio:</strong> TiendaPOS es un POS para gestionar operaciones comerciales conforme a las leyes locales.</p><p><strong>Responsabilidad fiscal:</strong> No es un sistema fiscal certificado. El usuario es responsable de sus obligaciones tributarias.</p><p><strong>Disponibilidad:</strong> Nos esforzamos por mantener el servicio 24/7, pero no garantizamos disponibilidad ininterrumpida.</p></div>
  </div>
</div>
<div class="modal-overlay fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-6 backdrop-blur-sm" id="modalLegal">
  <div class="w-full max-w-lg rounded-2xl bg-white p-8 shadow-2xl">
    <div class="mb-4 flex items-center justify-between"><h3 class="text-lg font-bold text-gray-900">Aviso Legal</h3><button class="modal-close rounded-lg p-1.5 text-gray-400 hover:text-gray-700"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
    <div class="space-y-3 text-sm leading-relaxed text-gray-600"><p><strong>Propiedad intelectual:</strong> TiendaPOS es software desarrollado de forma independiente. Todos los derechos reservados.</p><p><strong>Protección de datos:</strong> Datos almacenados en servidores de terceros (Neon.tech, Render) con sus certificaciones de seguridad.</p><p><strong>Jurisdicción:</strong> Este aviso se rige por las leyes de Venezuela.</p></div>
  </div>
</div>

<!-- Back to top -->
<button id="backToTop" class="fixed bottom-6 right-6 z-40 flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-lg text-gray-400 opacity-0 invisible transition-all hover:text-violet-600" aria-label="Arriba">
  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
</button>

<!-- WhatsApp FAB -->
<a href="https://wa.me/584247253544?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20TiendaPOS" target="_blank" class="fixed bottom-6 left-6 z-40 flex h-14 w-14 items-center justify-center rounded-full bg-[#25d366] text-white shadow-lg shadow-[#25d366]/30 transition-all hover:scale-110" aria-label="WhatsApp">
  <svg width="24" height="24" fill="currentColor" viewBox="0 0 448 512"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
</a>

<script is:inline>
(function(){
  document.querySelectorAll('.modal-close').forEach(function(btn){btn.addEventListener('click',function(){var m=this.closest('.modal-overlay');m.classList.add('hidden');m.classList.remove('flex');document.body.style.overflow='';});});
  document.querySelectorAll('.modal-overlay').forEach(function(o){o.addEventListener('click',function(e){if(e.target===this){this.classList.add('hidden');this.classList.remove('flex');document.body.style.overflow='';}});});
  document.querySelectorAll('.footer-link').forEach(function(l){l.addEventListener('click',function(e){e.preventDefault();var id=this.getAttribute('data-modal');if(id){var m=document.getElementById(id);m.classList.remove('hidden');m.classList.add('flex');document.body.style.overflow='hidden';}});});
  var b=document.getElementById('backToTop');
  window.addEventListener('scroll',function(){if(window.scrollY>400){b.classList.remove('opacity-0','invisible');b.classList.add('opacity-100');}else{b.classList.add('opacity-0','invisible');b.classList.remove('opacity-100');}},{passive:true});
  b.addEventListener('click',function(){window.scrollTo({top:0,behavior:'smooth'});});
})();
</script>
