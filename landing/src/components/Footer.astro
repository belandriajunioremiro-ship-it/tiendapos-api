    <!-- Links -->
    <div class="mb-6 text-sm">
      <a href="#" class="footer-link font-medium text-violet-200/70 no-underline transition-colors hover:text-white" data-modal="modalPrivacidad">Privacidad</a>
      <span class="mx-2 text-violet-400/30">·</span>
      <a href="#" class="footer-link font-medium text-violet-200/70 no-underline transition-colors hover:text-white" data-modal="modalTerminos">Términos</a>
      <span class="mx-2 text-violet-400/30">·</span>
      <a href="#" class="footer-link font-medium text-violet-200/70 no-underline transition-colors hover:text-white" data-modal="modalLegal">Aviso legal</a>
