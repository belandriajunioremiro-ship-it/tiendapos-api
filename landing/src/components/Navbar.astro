---
const links = [
  { href: '#funciones', label: 'Funciones' },
  { href: '#paises', label: 'Países' },
  { href: '#planes', label: 'Planes' },
  { href: '#faq', label: 'FAQ' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="#" class="flex items-center gap-2 text-xl font-extrabold no-underline text-gray-900">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="2" y="2" width="24" height="24" rx="6" stroke="#7c3aed" stroke-width="2.5"/><path d="M9 14h10M14 9v10" stroke="#7c3aed" stroke-width="2.5" stroke-linecap="round"/></svg>
      Tienda<span class="text-violet-600">POS</span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {links.map((l) => (
        <a href={l.href} class="text-sm font-medium text-gray-500 no-underline transition-colors hover:text-violet-600">{l.label}</a>
      ))}
      <a href="https://wa.me/584247253544?text=Hola%2C%20quiero%20probar%20TiendaPOS" target="_blank" class="inline-flex items-center gap-2 rounded-lg bg-violet-600 px-5 py-2.5 text-sm font-semibold text-white no-underline transition-all hover:bg-violet-700 hover:shadow-lg hover:shadow-violet-500/25">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        Probar gratis
      </a>
    </div>

    <button id="hamburgerBtn" class="flex flex-col gap-1.5 border-none bg-transparent p-2 md:hidden" aria-label="Menú">
      <span class="block h-0.5 w-5 rounded bg-gray-700 transition-all duration-300 origin-center" id="ham1" />
      <span class="block h-0.5 w-5 rounded bg-gray-700 transition-all duration-300" id="ham2" />
      <span class="block h-0.5 w-5 rounded bg-gray-700 transition-all duration-300 origin-center" id="ham3" />
    </button>
  </div>
</nav>

<div id="mobileMenu" class="fixed inset-0 z-[60] flex flex-col bg-white transition-all duration-300 translate-x-full">
  <div class="flex items-center justify-between px-6 py-4">
    <a href="#" class="flex items-center gap-2 text-xl font-extrabold no-underline text-gray-900">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="2" y="2" width="24" height="24" rx="6" stroke="#7c3aed" stroke-width="2.5"/><path d="M9 14h10M14 9v10" stroke="#7c3aed" stroke-width="2.5" stroke-linecap="round"/></svg>
      Tienda<span class="text-violet-600">POS</span>
    </a>
    <button id="closeMenuBtn" class="rounded-lg p-2 text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-700" aria-label="Cerrar">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="flex flex-1 flex-col items-center justify-center gap-6">
    {links.map((l) => (
      <a href={l.href} class="mobile-link text-2xl font-semibold text-gray-900 no-underline transition-colors hover:text-violet-600">{l.label}</a>
    ))}
    <a href="https://wa.me/584247253544?text=Hola%2C%20quiero%20probar%20TiendaPOS" target="_blank" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-violet-600 px-8 py-3 text-base font-semibold text-white no-underline transition-all hover:bg-violet-700">
      Probar gratis
    </a>
  </div>
</div>

<script is:inline>
(function(){
  var nav=document.getElementById('navbar');
  var menu=document.getElementById('mobileMenu');
  var open=document.getElementById('hamburgerBtn');
  var close=document.getElementById('closeMenuBtn');
  var links=document.querySelectorAll('.mobile-link');
  var h1=document.getElementById('ham1');
  var h2=document.getElementById('ham2');
  var h3=document.getElementById('ham3');
  var isOpen=false;

  function toggle(){
    isOpen=!isOpen;
    if(isOpen){
      menu.classList.remove('translate-x-full');
      menu.classList.add('translate-x-0');
      document.body.style.overflow='hidden';
      h1.style.transform='rotate(45deg) translate(3px,3px)';
      h2.style.opacity='0';
      h3.style.transform='rotate(-45deg) translate(3px,-3px)';
    }else{
      menu.classList.add('translate-x-full');
      menu.classList.remove('translate-x-0');
      document.body.style.overflow='';
      h1.style.transform='';
      h2.style.opacity='1';
      h3.style.transform='';
    }
  }

  open.addEventListener('click',toggle);
  close.addEventListener('click',toggle);
  links.forEach(function(l){l.addEventListener('click',function(){if(isOpen)toggle();});});

  var scrolled=false;
  window.addEventListener('scroll',function(){
    if(window.scrollY>10&&!scrolled){
      nav.classList.add('bg-white/90','backdrop-blur-lg','shadow-sm','border-b','border-gray-100');
      scrolled=true;
    }else if(window.scrollY<=10&&scrolled){
      nav.classList.remove('bg-white/90','backdrop-blur-lg','shadow-sm','border-b','border-gray-100');
      scrolled=false;
    }
  },{passive:true});
})();
</script>
