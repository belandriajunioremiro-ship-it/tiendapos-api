---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Pricing from '../components/Pricing.astro';
import Benefits from '../components/Benefits.astro';
import Features from '../components/Features.astro';
import Countries from '../components/Countries.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  <Hero />

  <div class="bg-gray-50/80 border-y border-gray-100">
    <div class="mx-auto flex max-w-[900px] flex-wrap items-center justify-center gap-8 px-6 py-8 text-center max-sm:gap-4 max-sm:py-6">
      <div>
        <div class="text-2xl font-black text-[#1a1a2e]">9</div>
        <div class="text-xs font-medium text-gray-400">países cubiertos</div>
      </div>
      <div class="h-8 w-px bg-gray-200 max-sm:hidden" />
      <div>
        <div class="text-2xl font-black text-[#1a1a2e]">112</div>
        <div class="text-xs font-medium text-gray-400">endpoints API</div>
      </div>
      <div class="h-8 w-px bg-gray-200 max-sm:hidden" />
      <div>
        <div class="text-2xl font-black text-[#1a1a2e]">4</div>
        <div class="text-xs font-medium text-gray-400">planes flexibles</div>
      </div>
      <div class="h-8 w-px bg-gray-200 max-sm:hidden" />
      <div>
        <div class="text-2xl font-black text-[#1a1a2e]">14</div>
        <div class="text-xs font-medium text-gray-400">días de prueba</div>
      </div>
    </div>
  </div>

  <div class="bg-white px-6 py-24">
    <div class="mx-auto max-w-[1140px]">
      <Benefits />
    </div>
  </div>

  <div class="bg-gray-50/80 px-6 py-24">
    <div class="mx-auto max-w-[1140px]">
      <Features />
    </div>
  </div>

  <div class="bg-white px-6 py-24">
    <div class="mx-auto max-w-[1140px]">
      <Countries />
    </div>
  </div>

  <div class="bg-gray-50/80 px-6 py-24">
    <div class="mx-auto max-w-[1140px]">
      <Pricing />
    </div>
  </div>

  <div class="bg-gradient-to-b from-white to-gray-50 px-6 py-24 text-center">
    <div class="mx-auto max-w-[600px] reveal">
      <h2 class="mb-4 text-[clamp(1.5rem,3vw,2rem)] font-bold text-[#1a1a2e]">
        ¿Listo para llevar tu negocio al <span class="text-violet-600">siguiente nivel</span>?
      </h2>
      <p class="mx-auto mb-8 max-w-[480px] text-base leading-relaxed text-gray-500">
        Únete a los comercios que ya confían en TiendaPOS para gestionar sus ventas en Latinoamérica.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="https://wa.me/584247253544?text=Hola%2C%20quiero%20probar%20TiendaPOS"
          target="_blank"
          class="glow-hover inline-flex items-center gap-2.5 rounded-xl bg-gradient-to-r from-violet-600 to-violet-700 px-7 py-3.5 text-sm font-bold text-white no-underline shadow-lg shadow-violet-500/25 transition-all hover:-translate-y-0.5"
        >
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Comenzar prueba gratis
        </a>
        <a
          href="https://wa.me/584247253544?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20TiendaPOS"
          target="_blank"
          class="inline-flex items-center gap-2.5 rounded-xl border-2 border-gray-200 bg-white px-7 py-3.5 text-sm font-bold text-gray-700 no-underline transition-all hover:border-violet-300 hover:text-violet-700 hover:shadow-sm"
        >
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          Contáctanos
        </a>
      </div>
    </div>
  </div>

  <Footer />

  <a href="https://wa.me/584247253544?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20TiendaPOS" target="_blank" class="fixed bottom-6 right-6 z-40 flex h-14 w-14 items-center justify-center rounded-full bg-[#25d366] text-white shadow-lg shadow-[#25d366]/35 transition-all hover:scale-110 hover:shadow-xl hover:shadow-[#25d366]/50" aria-label="WhatsApp">
    <svg width="26" height="26" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>
