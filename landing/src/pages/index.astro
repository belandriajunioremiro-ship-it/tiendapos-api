---
import Layout from '../layouts/Layout.astro';
const year = new Date().getFullYear();
---

<Layout>
  <!-- Mobile overlay -->
  <div class="nav-overlay fixed inset-0 z-90 hidden bg-black/40 opacity-0 transition-opacity duration-300" id="navOverlay"></div>

  <!-- Mobile menu -->
  <div class="mobile-menu fixed inset-0 z-95 flex flex-col items-center justify-center gap-2 bg-white/98 opacity-0 invisible transition-all duration-300 backdrop-blur-lg" id="mobileMenu">
    <button class="close-btn absolute right-5 top-4 rounded-xl p-2 text-gray-400 transition-all hover:bg-violet-50 hover:text-violet-600" id="closeMenuBtn">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <a href="#por-que" class="mobile-link rounded-xl px-8 py-3 text-xl font-semibold tracking-tight text-gray-900 no-underline transition-all hover:bg-violet-50 hover:text-violet-600">Por qué TiendaPOS</a>
    <a href="#caracteristicas" class="mobile-link rounded-xl px-8 py-3 text-xl font-semibold tracking-tight text-gray-900 no-underline transition-all hover:bg-violet-50 hover:text-violet-600">Características</a>
    <a href="#paises" class="mobile-link rounded-xl px-8 py-3 text-xl font-semibold tracking-tight text-gray-900 no-underline transition-all hover:bg-violet-50 hover:text-violet-600">Países</a>
