            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-violeta/10"><svg class="h-5 w-5 text-violeta" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg></div>
