    <a href="https://wa.me/584247253544?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20TiendaPOS" target="_blank" class="wa-link mt-6 inline-flex items-center gap-2 rounded-full bg-[#25d366] px-6 py-3 text-base font-semibold text-white no-underline transition-all hover:scale-105 hover:bg-[#1ebe5d]">
      <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Contáctanos
    </a>
  </div>

  <!-- Navbar -->
  <nav class="sticky top-0 z-50 border-b border-gray-200 bg-[#fafafa]/94 backdrop-blur-md">
    <div class="mx-auto flex max-w-[1140px] items-center justify-between px-6 py-3.5">
      <a href="#" class="text-xl font-extrabold no-underline text-[#1a1a2e]">Tienda<span class="text-violet-600">POS</span></a>
      <div class="hidden items-center gap-7 md:flex">
        <a href="#por-que" class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-violet-600">Por qué TiendaPOS</a>
        <a href="#caracteristicas" class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-violet-600">Características</a>
        <a href="#paises" class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-violet-600">Países</a>
        <a href="#planes" class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-violet-600">Planes</a>
        <a href="https://wa.me/584247253544?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20TiendaPOS" target="_blank" class="inline-flex items-center gap-1.5 rounded-full bg-[#25d366] px-4 py-2 text-xs font-semibold text-white no-underline transition-all hover:bg-[#1ebe5d]">
          <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contáctanos
        </a>
      </div>
      <button class="hamburger flex flex-col gap-1 border-none bg-transparent p-1.5 md:hidden" id="hamburgerBtn" aria-label="Menú">
        <span class="ham-line block h-0.5 w-5.5 rounded-sm bg-[#1a1a2e] transition-all duration-300"></span>
        <span class="ham-line block h-0.5 w-5.5 rounded-sm bg-[#1a1a2e] transition-all duration-300"></span>
        <span class="ham-line block h-0.5 w-5.5 rounded-sm bg-[#1a1a2e] transition-all duration-300"></span>
      </button>
    </div>
  </nav>

  <div class="mx-auto max-w-[1140px] px-6">
    <!-- Hero -->
    <section class="scroll-mt-[4.5rem] px-2 py-[clamp(3rem,6vw,5.5rem)] text-center">
      <h1 class="mx-auto mb-4 max-w-[780px] text-[clamp(1.8rem,5vw,3.5rem)] font-bold leading-tight text-[#1a1a2e]">
        Tu negocio merece un POS <span class="text-violet-600">sin fronteras</span>
      </h1>
      <p class="sub mx-auto mb-8 max-w-[680px] px-1 text-[clamp(0.95rem,2vw,1.1rem)] leading-relaxed text-gray-600">
        Multi-tenant, multimoneda y preparado para los regímenes fiscales de 9 países.
        Gestiona ventas, inventario, facturación y créditos desde un solo sistema.
      </p>
      <div class="mx-auto mt-8 max-w-[680px] rounded-xl border border-gray-200 bg-white/50 px-4 py-3 text-center text-sm leading-relaxed text-gray-600">
        Este sistema gestiona datos formales de facturación — <strong>RIF/NIT/RFC/RUC/CUIT</strong>, razones sociales e impuestos — para cumplir con requisitos contables y fiscales de cada país. <strong class="text-red-600">No es un sistema fiscal certificado</strong>. No realiza declaraciones de impuestos ni retenciones legales. Cada comercio es responsable de su propio cumplimiento fiscal local.
      </div>
    </section>

    <!-- Por qué TiendaPOS -->
    <h2 id="por-que" class="scroll-mt-[4.5rem] text-center text-[clamp(1.5rem,3vw,2rem)] font-bold text-[#1a1a2e]">Por qué TiendaPOS</h2>
    <p class="section-sub mx-auto mb-12 max-w-[640px] px-4 text-center text-base leading-relaxed text-gray-500">
      Construido para negocios que necesitan un sistema robusto, flexible y adaptado a la realidad latinoamericana.
    </p>

    <section class="vp-grid mb-6 grid grid-cols-[repeat(auto-fit,minmax(min(260px,100%),1fr))] gap-5">
      <div class="vp-card rounded-2xl border border-gray-200 bg-white p-6 transition-all hover:-translate-y-0.5 hover:border-violet-300 hover:shadow-lg hover:shadow-violet-500/10">
        <div class="icon mb-3 flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-violet-100 to-violet-50 text-violet-600">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3 class="mb-1 text-base font-bold text-[#1a1a2e]">Multi-tenant nativo</h3>
        <p class="text-sm leading-relaxed text-gray-500">Una sola instancia, múltiples tiendas aisladas. Ideal para cadenas, franquicias o negocios independientes.</p>
      </div>
      <div class="vp-card rounded-2xl border border-gray-200 bg-white p-6 transition-all hover:-translate-y-0.5 hover:border-violet-300 hover:shadow-lg hover:shadow-violet-500/10">
        <div class="icon mb-3 flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-violet-100 to-violet-50 text-violet-600">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <h3 class="mb-1 text-base font-bold text-[#1a1a2e]">Multimoneda real</h3>
        <p class="text-sm leading-relaxed text-gray-500">USD, VES, COP, MXN, ARS y más. Tasas de cambio con historial, pagos mixtos y cálculo de IGTF para Venezuela.</p>
      </div>
      <div class="vp-card rounded-2xl border border-gray-200 bg-white p-6 transition-all hover:-translate-y-0.5 hover:border-violet-300 hover:shadow-lg hover:shadow-violet-500/10">
        <div class="icon mb-3 flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-violet-100 to-violet-50 text-violet-600">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3 class="mb-1 text-base font-bold text-[#1a1a2e]">Facturación regional</h3>
        <p class="text-sm leading-relaxed text-gray-500">RIF, NIT, RFC, RUC, CUIT. IVA/IGV configurable por país. Facturas, cotizaciones, notas y devoluciones.</p>
      </div>
      <div class="vp-card rounded-2xl border border-gray-200 bg-white p-6 transition-all hover:-translate-y-0.5 hover:border-violet-300 hover:shadow-lg hover:shadow-violet-500/10">
        <div class="icon mb-3 flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-violet-100 to-violet-50 text-violet-600">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h3 class="mb-1 text-base font-bold text-[#1a1a2e]">API-first</h3>
        <p class="text-sm leading-relaxed text-gray-500">Backend Laravel con 112 endpoints protegidos con Sanctum. Consume desde cualquier frontend con total flexibilidad.</p>
      </div>
    </section>

    <!-- Características -->
    <h2 id="caracteristicas" class="scroll-mt-[4.5rem] text-center text-[clamp(1.5rem,3vw,2rem)] font-bold text-[#1a1a2e]">Todo lo que necesitas para operar</h2>
    <p class="section-sub mx-auto mb-12 max-w-[640px] px-4 text-center text-base leading-relaxed text-gray-500">
      Módulos completos que cubren cada aspecto del día a día de tu punto de venta.
    </p>

    <section class="features-grid mb-6 grid grid-cols-[repeat(auto-fit,minmax(min(300px,100%),1fr))] gap-3">
      <!-- 9 feature cards -->
      <div class="feature-card flex gap-3 rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-violet-300">
        <div class="icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-violet-100/80 text-violet-600">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div>
          <h4 class="mb-0.5 text-sm font-bold text-[#1a1a2e]">POS + Caja</h4>
          <p class="text-sm leading-relaxed text-gray-500">Pantalla de venta rápida. Sesiones de caja con apertura y cierre. Pagos mixtos y descuentos.</p>
        </div>
      </div>
      <div class="feature-card flex gap-3 rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-violet-300">
        <div class="icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-violet-100/80 text-violet-600">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <div>
          <h4 class="mb-0.5 text-sm font-bold text-[#1a1a2e]">Facturación</h4>
          <p class="text-sm leading-relaxed text-gray-500">Facturas, cotizaciones, notas de débito y devoluciones. Numeración correlativa por tipo.</p>
        </div>
      </div>
      <div class="feature-card flex gap-3 rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-violet-300">
        <div class="icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-violet-100/80 text-violet-600">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div>
          <h4 class="mb-0.5 text-sm font-bold text-[#1a1a2e]">Inventario</h4>
          <p class="text-sm leading-relaxed text-gray-500">Stock en tiempo real. Múltiples almacenes, lotes con FEFO, traslados y alertas de stock bajo.</p>
        </div>
      </div>
      <div class="feature-card flex gap-3 rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-violet-300">
        <div class="icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-violet-100/80 text-violet-600">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <div>
          <h4 class="mb-0.5 text-sm font-bold text-[#1a1a2e]">Multimoneda</h4>
          <p class="text-sm leading-relaxed text-gray-500">USD, VES, COP, MXN, ARS, PEN, CLP, BOB, UYU. Tasas de cambio con historial e IGTF.</p>
        </div>
      </div>
      <div class="feature-card flex gap-3 rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-violet-300">
        <div class="icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-violet-100/80 text-violet-600">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div>
          <h4 class="mb-0.5 text-sm font-bold text-[#1a1a2e]">Roles y permisos</h4>
          <p class="text-sm leading-relaxed text-gray-500">Administrador, supervisor y cajero. 69 permisos granulares para cada acción del sistema.</p>
        </div>
      </div>
      <div class="feature-card flex gap-3 rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-violet-300">
        <div class="icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-violet-100/80 text-violet-600">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <div>
          <h4 class="mb-0.5 text-sm font-bold text-[#1a1a2e]">Créditos</h4>
          <p class="text-sm leading-relaxed text-gray-500">Cuentas por cobrar, abonos y facturas a crédito con bloqueo para evitar sobreventa.</p>
        </div>
      </div>
      <div class="feature-card flex gap-3 rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-violet-300">
        <div class="icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-violet-100/80 text-violet-600">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
        </div>
        <div>
          <h4 class="mb-0.5 text-sm font-bold text-[#1a1a2e]">Reportes</h4>
          <p class="text-sm leading-relaxed text-gray-500">Ventas por período, rentabilidad, inventario y cuentas por cobrar. KPIs en tiempo real.</p>
        </div>
      </div>
      <div class="feature-card flex gap-3 rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-violet-300">
        <div class="icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-violet-100/80 text-violet-600">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
        </div>
        <div>
          <h4 class="mb-0.5 text-sm font-bold text-[#1a1a2e]">Suscripciones</h4>
          <p class="text-sm leading-relaxed text-gray-500">Trial, Básico, Pro, Premium. Límites por productos, usuarios, almacenes y cajas.</p>
        </div>
      </div>
      <div class="feature-card flex gap-3 rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-violet-300">
        <div class="icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-violet-100/80 text-violet-600">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div>
          <h4 class="mb-0.5 text-sm font-bold text-[#1a1a2e]">Onboarding</h4>
          <p class="text-sm leading-relaxed text-gray-500">Wizard de 4 pasos: cuenta, datos fiscales, configuración y primer producto.</p>
        </div>
      </div>
    </section>

    <!-- Países -->
    <h2 id="paises" class="scroll-mt-[4.5rem] text-center text-[clamp(1.5rem,3vw,2rem)] font-bold text-[#1a1a2e]">Países que soporta TiendaPOS</h2>
    <p class="section-sub mx-auto mb-12 max-w-[640px] px-4 text-center text-base leading-relaxed text-gray-500">
      Regímenes fiscales, monedas y métodos de pago nativos para cada país de la región.
    </p>

    <section class="countries-section mb-6">
      <div class="country-chips mb-3 flex flex-wrap items-center justify-center gap-2.5">
        <div class="chip flex h-13 w-13 items-center justify-center rounded-full border border-gray-200 bg-white shadow-sm transition-all hover:-translate-y-1 hover:border-violet-300 hover:shadow-md hover:shadow-violet-500/15"><span class="fi fi-ve block text-2xl leading-none"></span></div>
